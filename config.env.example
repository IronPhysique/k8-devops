# Homelab Configuration Template
# Copy this file to config.env and update with your actual values
#
# DO NOT commit config.env to Git!
# It's in .gitignore to protect your network configuration

# Network Configuration
NETWORK="192.168.1.0/24"  # UPDATE: Your home network

# Management Cluster (Raspberry Pi 5)
MGMT_HOSTNAME="controller.local"
MGMT_IP="192.168.1.10"  # UPDATE: Your Pi's actual IP

# Apps Cluster (Office PC)
APPS_HOSTNAME="server.local"
APPS_IP="192.168.1.20"  # UPDATE: Your PC's actual IP

# Additional worker nodes (if adding more)
APPS_WORKER2_HOSTNAME="worker2.local"  # Optional
APPS_WORKER2_IP="192.168.1.21"  # Optional

# Pi-hole LoadBalancer IP (reserve this in your router)
PIHOLE_LB_IP="192.168.1.53"  # UPDATE: Reserve this IP in your router

# GitHub (optional - the repo URL used by ArgoCD is set in argocd/applicationsets/)
GITHUB_USERNAME="YOUR_USERNAME"  # UPDATE: Your GitHub username
GITHUB_REPO="https://github.com/${GITHUB_USERNAME}/k8-devops.git"

# Export for use in scripts
export NETWORK MGMT_HOSTNAME MGMT_IP APPS_HOSTNAME APPS_IP PIHOLE_LB_IP GITHUB_USERNAME GITHUB_REPO

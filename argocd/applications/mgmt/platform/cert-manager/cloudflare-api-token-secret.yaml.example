# Example Cloudflare API Token Secret
#
# To use this:
# 1. Create a Cloudflare API token with DNS edit permissions for iron-lab.org
# 2. Copy this file to cloudflare-api-token-secret.yaml (gitignored)
# 3. Replace YOUR_CLOUDFLARE_API_TOKEN with your actual token
# 4. Use kubeseal to create a SealedSecret:
#    kubeseal --format=yaml < cloudflare-api-token-secret.yaml > cloudflare-api-token-sealedsecret.yaml
# 5. Commit the SealedSecret to git
#
---
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: cert-manager
type: Opaque
stringData:
  api-token: YOUR_CLOUDFLARE_API_TOKEN
